# Copied to .env.local for local overrides (see README). Do not commit .env.local.

# Vercel / preview: keep false or omit; chat is also off when VERCEL=1.
OLLAMA_CHAT_ENABLED=false

# Local dev with Ollama: in .env.local use true (or remove OLLAMA_CHAT_ENABLED).
# OLLAMA_CHAT_ENABLED=true

# Optional: remote Ollama (default local: http://127.0.0.1:11434)
# OLLAMA_HOST=http://127.0.0.1:11434
